{
  "__inputs": [
    {
      "name": "DS_WORKDESK_D1",
      "label": "WorkDesk D1 (JSON API)",
      "description": "Point this at the /api/incidents, /api/admin-actions, /api/audit endpoints served by the admin worker",
      "type": "datasource",
      "pluginId": "marcusolsson-json-datasource",
      "pluginName": "JSON API"
    }
  ],
  "title": "WorkDesk Security Admin",
  "uid":   "workdesk-security",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Pending Admin Actions",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/admin-actions?status=pending",
          "fields": [{ "name": "actions", "type": "array" }]
        }
      ],
      "options": { "reduceOptions": { "calcs": ["count"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Open Incidents",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/incidents?status=open",
          "fields": [{ "name": "incidents", "type": "array" }]
        }
      ],
      "options": { "reduceOptions": { "calcs": ["count"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "DLQ Depth",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/admin-actions?status=dlq",
          "fields": [{ "name": "actions", "type": "array" }]
        }
      ],
      "options": { "reduceOptions": { "calcs": ["count"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Audit Chain Health",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "description": "Reads latest nightly manifest from R2 via the admin API",
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/audit/manifest/latest",
          "fields": [{ "name": "ok", "type": "boolean" }]
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "mappings": [
          { "type": "value", "options": { "true":  { "text": "OK",   "color": "green" } } },
          { "type": "value", "options": { "false": { "text": "FAIL", "color": "red"   } } }
        ]
      }
    },
    {
      "id": 5,
      "title": "Incidents by Severity (24 h)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/incidents",
          "fields": [{ "name": "incidents[*].severity", "type": "string" }]
        }
      ]
    },
    {
      "id": 6,
      "title": "Admin Actions Timeline",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 4, "w": 16, "h": 8 },
      "description": "Count of admin actions per hour, grouped by status",
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/admin-actions",
          "fields": [
            { "name": "actions[*].created_at", "type": "time"   },
            { "name": "actions[*].status",     "type": "string" }
          ]
        }
      ]
    },
    {
      "id": 7,
      "title": "Approval Latency P95 (minutes)",
      "type": "gauge",
      "description": "P95 time between action creation and approval/rejection decision. Computed client-side from API data.",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": "${DS_WORKDESK_D1}",
          "urlPath": "/api/admin-actions?status=approved&limit=200",
          "fields": [
            { "name": "actions[*].created_at", "type": "time" },
            { "name": "actions[*].updated_at", "type": "time" }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30   },
              { "color": "red",    "value": 120  }
            ]
          }
        }
      }
    }
  ]
}
